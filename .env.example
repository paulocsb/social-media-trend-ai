DATABASE_URL=postgresql://postgres:password@localhost:5432/trend_db
REDIS_URL=redis://localhost:6379
# Optional — Instagram Graph API tokens (comma-separated)
IG_TOKENS=
JWT_SECRET=change_me_to_at_least_32_characters_long
# Password for the admin user (min 8 chars). Set on first deploy — hashed and stored in DB.
ADMIN_PASSWORD=
PORT=3000

# Optional — enable additional data sources
APIFY_TOKEN=
RAPID_API_KEY=

# Collector configuration
TRACKED_HASHTAGS=marketing,socialmedia
TRACKED_COMPETITORS=nike,adidas
NICHE_HASHTAG=marketing

# Frontend
VITE_API_URL=http://localhost:3000
